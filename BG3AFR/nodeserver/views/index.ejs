<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/site.css">
  <link rel="icon" type="image/png" href="https://baldursgate3.game/favicon-32x32.png">
</head>
<body>
  <main>
    <p class="eyebrow"><%= title %></p>
    <h1>Install checklist</h1>
    <div class="restart-section">
      <button id="restart-button" class="action-button restart-button" type="button">Restart Setup</button>
      <button id="clear-downloads-button" class="action-button clear-downloads-button" type="button">Clear Download Cache</button>
      <button id="clear-mods-button" class="action-button clear-mods-button" type="button">Clear Extracted Mods Cache</button>
    </div>
    <p class="intro-text">Follow this checklist steps by steps. <br>Do not close the "Windows PowerShell" window during the setup process.</p>
    <section class="checklist" aria-label="Setup checklist">
      <div class="checklist-item checklist-item--checked">
        <span class="checkmark" aria-hidden="true">✓</span>
        <div>
          <h2>Node.js and npm installed</h2>
          <p>Ready to run the local toolchain.</p>
        </div>
      </div>

      <div class="checklist-item" id="bg3-installation-item">
        <span class="checkmark" aria-hidden="true">○</span>
        <div>
          <h2>Clean Install of Baldur's Gate 3</h2>
          <p id="find-bg3-status" aria-live="polite">Not checked yet.</p>
          <button id="find-bg3-folder" class="action-button" type="button">Find Baldur's Gate 3 installation folder</button>
          <form id="manual-bg3-form" class="manual-form" hidden>
            <label for="manual-bg3-path">Set folder manually</label>
            <input id="manual-bg3-path" name="manualBg3Path" type="text" placeholder="C:\Program Files (x86)\Steam\steamapps\common\Baldur's Gate 3" autocomplete="off">
            <button type="submit" class="action-button">Save this path</button>
          </form>
        </div>
      </div>

      <div class="checklist-item" id="bg3-mods-folder-item">
    <span class="checkmark" aria-hidden="true">○</span>
    <div>
      <h2>Baldur's Gate 3 Mods Folder</h2>
      <p id="find-bg3-mods-status" class="status" aria-live="polite">Not checked yet.</p>
      <button id="find-bg3-mods-folder" class="action-button" type="button">Find Baldur's Gate 3 Mods folder</button>
    </div>
    </div>

      <div class="checklist-item" id="install-bg3-mod-manager-item">
    <span class="checkmark" aria-hidden="true">○</span>
    <div>
      <h2>Install BG3ModManager</h2>
      <p id="install-bg3mm-status" class="status" aria-live="polite">Checking BG3 Mod Manager installation...</p>
      <button id="install-bg3mm-button" class="action-button" type="button">Install BG3ModManager</button>
    </div>
    </div>

      <div class="checklist-item" id="select-modlist-item">
    <span class="checkmark" aria-hidden="true">○</span>
    <div>
      <h2>Select modlist</h2>
      <p id="select-modlist-status" class="status" aria-live="polite">Loading modlists...</p>
      <label for="modlist-dropdown">Choose a modlist:</label>
      <div class="modlist-controls">
        <select id="modlist-dropdown" class="modlist-dropdown" aria-describedby="modlist-description">
          <option value="">Loading...</option>
        </select>
        <button id="import-modlist-button" class="action-button" type="button">Import</button>
        <input id="modlist-file-input" type="file" accept=".json" hidden>
      </div>
      <div id="modlist-description-container" hidden>
        <p id="modlist-description" class="modlist-description"></p>
      </div>
      <button id="install-selected-modlist-button" class="action-button" type="button">Install the currently selected modlist</button>
    </div>
    </div>

      <div class="checklist-item" id="download-mods-item">
    <span class="checkmark" aria-hidden="true">○</span>
    <div>
      <h2>Download mod.io mods</h2>
      <p id="download-mods-status" class="status" aria-live="polite">Ready to download mods.</p>
      <button id="start-download" class="action-button" type="button">Start Download</button>
      <div id="download-progress" hidden>
        <button id="toggle-mod-list" class="toggle-button" type="button" hidden>▼ Hide Downloads</button>
        <ul id="mod-download-list" class="mod-list"></ul>
      </div>
    </div>
    </div>

      <div class="checklist-item" id="download-rpghq-item">
    <span class="checkmark" aria-hidden="true">○</span>
    <div>
      <h2>Download rpghq.org and others mods</h2>
      <p id="download-rpghq-status" class="status" aria-live="polite">Ready to download mods.</p>
      <button id="start-download-rpghq" class="action-button" type="button">Start Download</button>
      <div id="download-rpghq-progress" hidden>
        <button id="toggle-rpghq-list" class="toggle-button" type="button" hidden>▼ Hide Downloads</button>
        <ul id="rpghq-download-list" class="mod-list"></ul>
      </div>
    </div>
    </div>

      <div class="checklist-item" id="download-nexusmods-item">
    <span class="checkmark" aria-hidden="true">○</span>
    <div>
      <h2>Download nexusmods.com mods</h2>
      <p id="download-nexusmods-status" class="status" aria-live="polite">Ready to download mods.</p>
      <form id="nexusmods-api-form" class="manual-form">
        <p>Get it <a href="https://www.nexusmods.com/settings/api-keys" target="_blank" rel="noopener noreferrer">here</a>: Personal API Key</p>
        <label for="nexusmods-api-key">Nexus Mods API Key</label>
        <input id="nexusmods-api-key" name="nexusModsApiKey" type="password" placeholder="Enter your Nexus Mods API key" autocomplete="off">
      </form>
      <button id="start-download-nexusmods" class="action-button" type="button">Start Download</button>
      <div id="download-nexusmods-progress" hidden>
        <button id="toggle-nexusmods-list" class="toggle-button" type="button" hidden>▼ Hide Downloads</button>
        <ul id="nexusmods-download-list" class="mod-list"></ul>
      </div>
    </div>
    </div>

      <div class="checklist-item" id="extract-packages-item">
    <span class="checkmark" aria-hidden="true">○</span>
    <div>
      <h2>Extract mods files</h2>
      <p id="extract-packages-status" class="status" aria-live="polite">Ready to extract mods.</p>
      <button id="start-extract" class="action-button" type="button">Start Extraction</button>
      <div id="extract-progress" hidden>
        <button id="toggle-extract-list" class="toggle-button" type="button" hidden>▼ Hide Extractions</button>
        <ul id="extract-list" class="mod-list"></ul>
      </div>
    </div>
    </div>

      <div class="checklist-item" id="install-files-item">
    <span class="checkmark" aria-hidden="true">○</span>
    <div>
      <h2>Install mod Files</h2>
      <p id="install-files-status" class="status" aria-live="polite">Ready to install mod files.</p>
      <button id="start-install-files" class="action-button" type="button">Install mod Files</button>
      <div id="install-progress" hidden>
        <button id="toggle-install-list" class="toggle-button" type="button" hidden>▼ Hide Installations</button>
        <ul id="install-list" class="mod-list"></ul>
      </div>
    </div>
    </div>

      <div class="checklist-item" id="set-load-order-item">
    <span class="checkmark" aria-hidden="true">○</span>
    <div>
      <h2>Set Load Order</h2>
      <p id="set-load-order-status" class="status" aria-live="polite">Ready to set load order.</p>
      <button id="start-set-load-order" class="action-button" type="button">Set Load Order</button>
    </div>
    </div>
    </section>
    <div class="badge">Port 3001 · Express + EJS</div>
  </main>
  <script src="/app.js"></script>
</body>
</html>
