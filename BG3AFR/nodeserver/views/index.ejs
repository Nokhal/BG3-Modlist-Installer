<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %></title>
  <link rel="stylesheet" href="/site.css">
  <link rel="icon" type="image/png" href="https://baldursgate3.game/favicon-32x32.png">
</head>
<body>
  <main>
    <p class="eyebrow"><%= title %></p>
    <h1>Install checklist</h1>
    <p class="intro-text">Follow this checklist steps by steps. <br>Do not close the "Windows PowerShell" window during the setup process.</p>
    <section class="checklist" aria-label="Setup checklist">
      <div class="checklist-item checklist-item--checked">
        <span class="checkmark" aria-hidden="true">✓</span>
        <div>
          <h2>Node.js and npm installed</h2>
          <p>Ready to run the local toolchain.</p>
        </div>
      </div>

      <div class="checklist-item" id="bg3-installation-item">
        <span class="checkmark" aria-hidden="true">○</span>
        <div>
          <h2>Install Baldur's Gate 3</h2>
          <p id="find-bg3-status" aria-live="polite">Not checked yet.</p>
          <button id="find-bg3-folder" class="action-button" type="button">Find Baldur's Gate 3 installation folder</button>
          <form id="manual-bg3-form" class="manual-form" hidden>
            <label for="manual-bg3-path">Set folder manually</label>
            <input id="manual-bg3-path" name="manualBg3Path" type="text" placeholder="C:\Program Files (x86)\Steam\steamapps\common\Baldur's Gate 3" autocomplete="off">
            <button type="submit" class="action-button">Save this path</button>
          </form>
        </div>
      </div>

      <div class="checklist-item" id="bg3-mods-folder-item">
    <span class="checkmark" aria-hidden="true">○</span>
    <div>
      <h2>Baldur's Gate 3 Mods Folder</h2>
      <p id="find-bg3-mods-status" class="status" aria-live="polite">Not checked yet.</p>
      <button id="find-bg3-mods-folder" class="action-button" type="button">Find Baldur's Gate 3 Mods folder</button>
    </div>
    </div>

      <div class="checklist-item" id="download-mods-item">
    <span class="checkmark" aria-hidden="true">○</span>
    <div>
      <h2>Download mod.io mods</h2>
      <p id="download-mods-status" class="status" aria-live="polite">Ready to download mods.</p>
      <button id="start-download" class="action-button" type="button">Start Download</button>
      <div id="download-progress" hidden>
        <button id="toggle-mod-list" class="toggle-button" type="button" hidden>▼ Hide Downloads</button>
        <ul id="mod-download-list" class="mod-list"></ul>
      </div>
    </div>
    </div>

      <div class="checklist-item" id="download-rpghq-item">
    <span class="checkmark" aria-hidden="true">○</span>
    <div>
      <h2>Download rpghq.org mods</h2>
      <p id="download-rpghq-status" class="status" aria-live="polite">Ready to download mods.</p>
      <button id="start-download-rpghq" class="action-button" type="button">Start Download</button>
      <div id="download-rpghq-progress" hidden>
        <button id="toggle-rpghq-list" class="toggle-button" type="button" hidden>▼ Hide Downloads</button>
        <ul id="rpghq-download-list" class="mod-list"></ul>
      </div>
    </div>
    </div>

      <div class="checklist-item" id="extract-packages-item">
    <span class="checkmark" aria-hidden="true">○</span>
    <div>
      <h2>Extract mods .pak files</h2>
      <p id="extract-packages-status" class="status" aria-live="polite">Ready to extract mods.</p>
      <button id="start-extract" class="action-button" type="button">Start Extraction</button>
      <div id="extract-progress" hidden>
        <button id="toggle-extract-list" class="toggle-button" type="button" hidden>▼ Hide Extractions</button>
        <ul id="extract-list" class="mod-list"></ul>
      </div>
    </div>
    </div>
    </section>
    <div class="badge">Port 3001 · Express + EJS</div>
  </main>
  <script src="/app.js"></script>
</body>
</html>
